# Main
PROJECT_NAME=project
GITHUB_USER_NAME=gituser

# Application mode (dev | prod) & (development | production) IMPORTANT BOTH!
MODE=dev
MODE_NODE_ENV=development

# Application domain (e.g. test.google.tst)
DOMAIN=localhost

# Development user UID and name
DEV_USER_ID=1000
DEV_USER_NAME=devuser

# Network settings
HTTPS_PORT=443
HTTP_PORT=80

# Database connection settings
DB_DRIVER=mysql
DB_HOST=db
DB_PORT=3306
DB_VERSION=11.8.5-MariaDB
DB_CHARSET=utf8mb4

# Database credentials
DB_ROOT_PASSWORD=root_password
DB_USER=db_user
DB_PASSWORD=db_password
DB_DATABASE=main
